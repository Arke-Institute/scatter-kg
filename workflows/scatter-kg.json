{
  "label": "Scatter KG Extraction",
  "description": "Scatters entity IDs to KG extractor for parallel knowledge graph extraction, deduplication, and clustering",
  "version": "1.2",
  "entry": "scatter",
  "flow": {
    "scatter": {
      "klados": { "id": "$SCATTER_KLADOS" },
      "then": { "scatter": "extract" }
    },
    "extract": {
      "klados": { "id": "$KG_EXTRACTOR_KLADOS" },
      "then": { "scatter": "dedupe" }
    },
    "dedupe": {
      "klados": { "id": "$KG_DEDUPE_RESOLVER_KLADOS" },
      "then": { "scatter": "cluster" }
    },
    "cluster": {
      "klados": { "id": "$KG_CLUSTER_KLADOS" },
      "then": { "done": true }
    }
  }
}
